{
  "dashboard": {
    "id": null,
    "uid": "vpd-monitoring",
    "title": "VPD Climate Monitoring",
    "tags": ["vpd", "mushroom", "climate"],
    "timezone": "browser",
    "schemaVersion": 38,
    "refresh": "30s",
    "time": {
      "from": "now-12h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "type": "timeseries",
        "title": "Temperature & Humidity (12h)",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 24,
          "h": 8
        },
        "targets": [
          {
            "refId": "A",
            "datasource": "Home Assistant",
            "entity_id": "sensor.chamber_avg_temp",
            "alias": "Temperature"
          },
          {
            "refId": "B",
            "datasource": "Home Assistant",
            "entity_id": "sensor.chamber_avg_humidity",
            "alias": "Humidity"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "axisCenteredZero": false,
              "axisLabel": "",
              "axisPlacement": "auto",
              "barAlignment": 0,
              "drawStyle": "line",
              "fillOpacity": 10,
              "gradientMode": "none",
              "lineInterpolation": "smooth",
              "lineWidth": 2,
              "pointSize": 5,
              "scaleDistribution": {
                "type": "linear"
              },
              "showPoints": "never",
              "spanNulls": true
            },
            "unit": "celsius"
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Temperature"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "fixedColor": "#2196F3",
                    "mode": "fixed"
                  }
                },
                {
                  "id": "custom.axisPlacement",
                  "value": "left"
                },
                {
                  "id": "min",
                  "value": 10
                },
                {
                  "id": "max",
                  "value": 25
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "Humidity"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "fixedColor": "#00BCD4",
                    "mode": "fixed"
                  }
                },
                {
                  "id": "custom.axisPlacement",
                  "value": "right"
                },
                {
                  "id": "unit",
                  "value": "percent"
                },
                {
                  "id": "min",
                  "value": 70
                },
                {
                  "id": "max",
                  "value": 100
                }
              ]
            }
          ]
        },
        "options": {
          "legend": {
            "calcs": ["lastNotNull", "mean"],
            "displayMode": "table",
            "placement": "bottom",
            "showLegend": true
          },
          "tooltip": {
            "mode": "multi",
            "sort": "none"
          }
        }
      },
      {
        "id": 2,
        "type": "timeseries",
        "title": "VPD (12h)",
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 24,
          "h": 7
        },
        "targets": [
          {
            "refId": "A",
            "datasource": "Home Assistant",
            "entity_id": "sensor.chamber_current_vpd_2",
            "alias": "VPD"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "axisCenteredZero": false,
              "axisLabel": "kPa",
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 20,
              "gradientMode": "opacity",
              "lineInterpolation": "smooth",
              "lineWidth": 3,
              "pointSize": 5,
              "scaleDistribution": {
                "type": "linear"
              },
              "showPoints": "never",
              "spanNulls": true,
              "thresholdsStyle": {
                "mode": "line"
              }
            },
            "unit": "pressurekpa",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "#2196F3",
                  "value": 0.15
                },
                {
                  "color": "#4CAF50",
                  "value": 0.20
                }
              ]
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "VPD"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "fixedColor": "#4CAF50",
                    "mode": "fixed"
                  }
                }
              ]
            }
          ]
        },
        "options": {
          "legend": {
            "calcs": ["lastNotNull", "mean", "min", "max"],
            "displayMode": "table",
            "placement": "bottom",
            "showLegend": true
          },
          "tooltip": {
            "mode": "multi",
            "sort": "none"
          }
        }
      },
